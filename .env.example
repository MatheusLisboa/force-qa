# Supabase (obrigatório)
VITE_SUPABASE_URL="https://bdvpzgrgwgcvfgflelbn.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY_AQUI"

# Supabase service role — apenas no servidor (admin criar usuários)
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY_AQUI"

# Gemini AI (opcional — sugestões de bug e duplicidade legado)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI Report — provider: openrouter | ollama (padrão: openrouter se OPENROUTER_API_KEY estiver definida)
AI_PROVIDER="openrouter"

# OpenRouter (recomendado para produção — baixo custo)
OPENROUTER_API_KEY="SUA_OPENROUTER_KEY"
OPENROUTER_MODEL="google/gemini-2.5-flash"

# Ollama (local / sem custo de API)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"
